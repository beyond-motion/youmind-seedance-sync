{
  "name": "youmind-seedance-sync",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch": "node scripts/fetch-prompts.mjs",
    "bootstrap:lark": "node scripts/bootstrap-feishu-via-lark.mjs",
    "sync:lark": "node scripts/sync-feishu-lark.mjs",
    "sync:lark:local-auth": "bash scripts/run-sync-lark-local.sh",
    "sync:r2": "node scripts/sync-r2-videos.mjs",
    "set:r2-public-url": "node scripts/set-r2-public-url.mjs",
    "rewrite:r2-urls": "node scripts/rewrite-r2-video-urls.mjs",
    "sync:api": "node scripts/sync-feishu-api.mjs",
    "setup:r2": "node scripts/setup-r2.mjs",
    "deploy:video-gate": "npx wrangler deploy --config workers/r2-video-gate/wrangler.toml",
    "deploy:seedance-site": "npx wrangler deploy --config workers/seedance-site/wrangler.toml",
    "disable:r2-dev-url": "node scripts/disable-r2-dev-url.mjs",
    "setup:runner": "bash scripts/setup-self-hosted-runner.sh",
    "build:site": "node scripts/build-site.mjs",
    "analyze:prompts": "node scripts/analyze-prompts.mjs",
    "analyze:prompts:stable": "node scripts/analyze-prompts.mjs --stable",
    "prepare:site": "node scripts/fetch-prompts.mjs && node scripts/build-site.mjs",
    "collect:aimikoda-seedance": "node scripts/collect-aimikoda-seedance.mjs"
  }
}
